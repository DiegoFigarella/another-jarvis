# WhatsApp / Evolution API
EVOLUTION_API_BASE_URL=http://localhost:8080
EVOLUTION_API_TOKEN=your_api_token_here
WHATSAPP_NUMBER=

# LangChain agent
model=anthropic:claude-sonnet-4-6 # you may also use openai:gpt-5.4-mini 
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Browser use (web browsing tool). Falls back to `model` above if unset.
BROWSER_USE_MODEL=
BROWSER_USE_API_KEY=
# Empty uses browser-use's managed Chromium. Point at your installed Chrome to
# use your own profile, e.g. C:\Program Files\Google\Chrome\Application\chrome.exe
CHROME_PATH=

# Speech to text: "openai" or "whisper_cpp"
STT_BACKEND=openai
OPENAI_TRANSCRIPTION_MODEL=whisper-1
OPENAI_TRANSCRIPTION_PROMPT=WhatsApp. Send a text message to.

# Empty uses the system default microphone. You may also use an index or a
# case-insensitive name substring, for example: 0 or MacBook Pro Microphone.
INPUT_DEVICE=

# Only required when STT_BACKEND=whisper_cpp
WHISPER_CPP_DIR=
WHISPER_MODEL=
WHISPER_SERVER=
